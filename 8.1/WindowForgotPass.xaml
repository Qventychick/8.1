<Window x:Class="Практическая_8.WindowForgotPass"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Практическая_8"
        mc:Ignorable="d"
        Title="Забыли пароль" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FF8082FF" Offset="0.69"/>
            <GradientStop Color="#FF0003B3" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <TextBox x:Name="textB1" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Top" Width="426" TextChanged="TextBox_TextChanged" FontSize="20" Margin="0,216,0,0"/>
        <Label x:Name="label2" Content="Введите адрес электронной почты" HorizontalAlignment="Center" Margin="0,161,0,0" VerticalAlignment="Top" 
FontSize="22" FontFamily="Arial" FontWeight="Bold"/>
        <Button x:Name="btn1" Content="Подтвердить" 
        HorizontalAlignment="Center" Margin="0,343,0,0" VerticalAlignment="Top" 
        FontSize="24" Height="54" Width="192" Background="White" FontFamily="Arial" Click="Button_Click">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>
        <Label HorizontalAlignment="Center" Margin="0,33,0,0" VerticalAlignment="Top" 
       FontSize="20" FontFamily="Arial" FontWeight="Bold">
            <TextBlock x:Name="label1" TextAlignment="Center" FontSize="24"><Run Text="Пароль улетел?"/><LineBreak/><Run Text="Голубь его вернет!"/></TextBlock>
        </Label>
        <Button x:Name="btn2" Content="К авторизации" HorizontalAlignment="Left" Margin="22,343,0,0" VerticalAlignment="Top" FontSize="24" Height="54" Width="192" Background="White" FontFamily="Arial" Click="Button_Click2" Visibility="Hidden">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>
