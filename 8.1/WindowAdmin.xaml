<Window x:Class="Практическая_8.WindowAdmin"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:local="clr-namespace:Практическая_8"
mc:Ignorable="d"
Title="Панель администратора" Height="467" Width="825" WindowStartupLocation="CenterScreen">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FF8082FF" Offset="0.535"/>
            <GradientStop Color="#FF0003B3" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <TabControl>
            <TabItem Header="Просмотр данных" Margin="-2,-2,-2,0">
                <Grid>
                    <Grid.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF8082FF" Offset="0.25"/>
                            <GradientStop Color="#FF3700FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <DataGrid d:ItemsSource="{d:SampleData ItemCount=20}" AutoGenerateColumns="False" SelectionChanged="DataGrid_SelectionChanged_1" Height="153" VerticalAlignment="Top" FontSize="14">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding ФИО}" Width="213"/>
                            <DataGridTextColumn Header="контактные данные" Binding="{Binding инфа}" Width="200"/>
                            <DataGridTextColumn Header="адрес проживания" Binding="{Binding адрес}" Width="200"/>
                            <DataGridTextColumn Header="дата регистрации" Binding="{Binding дата}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <ListBox Margin="0,274,-6,-28">
                        <ListBoxItem Content="ФИО: заявка, заявка, заявка" FontSize="16"/>
                        <ListBoxItem Content="ФИО: заявка, заявка, заявка" FontSize="16"/>
                        <ListBoxItem Content="ФИО: заявка, заявка, заявка" FontSize="16"/>
                    </ListBox>
                    <TextBox HorizontalAlignment="Left" Margin="79,243,0,0" TextWrapping="Wrap" Text="&#xD;&#xA;" VerticalAlignment="Top" Width="120" Height="21"/>
                    <Label Margin="10,238,0,0" VerticalAlignment="Top" x:Name="label7" HorizontalAlignment="Left" FontSize="18" FontWeight="Bold" FontFamily="Arial" Content="Поиск"/>
                    <Button Content="Сессии"  HorizontalAlignment="Left" Margin="674,0,0,0" VerticalAlignment="Center" FontSize="20" Height="45" Width="124" Background="White" FontFamily="Arial" Click="Button_Click">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </TabItem>
            <TabItem Header="Регистрация пользователя" Margin="-2,-2,-2,0">
                <Grid Background="#FFE5E5E5">
                    <Grid>
                        <Grid.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF8082FF" Offset="0.25"/>
                                <GradientStop Color="#FF3700FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Grid.Background>
                        <Label VerticalAlignment="Top" x:Name="label1" Margin="176,-2,0,0" HorizontalAlignment="Left" FontSize="22" FontWeight="Bold" FontFamily="Arial" Content="Введите данные о новом пользователе"/>
                        <TextBox Width="290" VerticalAlignment="Top" Text="&#xA;" TextWrapping="Wrap" Margin="270,47,0,0" Height="22" HorizontalAlignment="Left" SelectionOpacity="0"/>
                        <TextBox Width="290" VerticalAlignment="Top" Text="&#xA;" TextWrapping="Wrap" Height="22" HorizontalAlignment="Left" SelectionOpacity="0" Margin="270,80,0,0"/>
                        <TextBox Width="290" VerticalAlignment="Top" Text="&#xA;" TextWrapping="Wrap" Margin="270,114,0,0" Height="22" HorizontalAlignment="Left" SelectionOpacity="0"/>
                        <TextBox Width="290" VerticalAlignment="Top" Text="&#xA;" TextWrapping="Wrap" Margin="270,148,0,0" Height="22" HorizontalAlignment="Left" SelectionOpacity="0"/>
                        <TextBox Width="290" VerticalAlignment="Top" Text="&#xA;" TextWrapping="Wrap" Margin="270,183,0,0" Height="22" HorizontalAlignment="Left" SelectionOpacity="0"/>
                        <ListBox Margin="0,289,-6,-28">
                            <ListBoxItem Content="ФИО: логин, пароль" FontSize="16"/>
                            <ListBoxItem Content="ФИО: логин, пароль" FontSize="16"/>
                            <ListBoxItem Content="ФИО: логин, пароль" FontSize="16"/>
                        </ListBox>
                        <Label Margin="160,43,0,0" VerticalAlignment="Top" x:Name="label2" HorizontalAlignment="Left" FontSize="18" FontWeight="Bold" FontFamily="Arial" Content="Фамилия"/>
                        <Label VerticalAlignment="Top" x:Name="label3" Margin="205,76,0,0" HorizontalAlignment="Left" FontSize="18" FontWeight="Bold" FontFamily="Arial" Content="Имя"/>
                        <Label VerticalAlignment="Top" x:Name="label4" Margin="159,110,0,0" HorizontalAlignment="Left" FontSize="18" FontWeight="Bold" FontFamily="Arial" Content="Отчество"/>
                        <Label VerticalAlignment="Top" x:Name="label5" Margin="189,144,0,0" HorizontalAlignment="Left" FontSize="18" FontWeight="Bold" FontFamily="Arial" Content="Логин"/>
                        <Label VerticalAlignment="Top" x:Name="label6" Margin="175,179,0,0" HorizontalAlignment="Left" FontSize="18" FontWeight="Bold" FontFamily="Arial" Content="Пароль"/>
                        <TextBox Width="290" VerticalAlignment="Top" Text="&#xA;" TextWrapping="Wrap" Margin="270,218,0,0" Height="22" HorizontalAlignment="Left" SelectionOpacity="0"/>
                        <Label VerticalAlignment="Top" x:Name="label12" Margin="68,214,0,0" HorizontalAlignment="Left" FontSize="18" FontWeight="Bold" FontFamily="Arial" Content="Подтвердите пароль"/>
                        <Button x:Name="btn10" Content="Создать" HorizontalAlignment="Center" Margin="0,250,0,0" VerticalAlignment="Top" FontSize="16" Height="29" Width="158" Background="White" FontFamily="Arial" Click="Button_Click1">
                            <Button.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Изменение данных пользоваетля" Margin="-2,-2,-2,0">
                <Grid Background="#FFE5E5E5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="59*"/>
                            <ColumnDefinition Width="214*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF8082FF" Offset="0.25"/>
                                <GradientStop Color="#FF3700FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Grid.Background>
                        <Button x:Name="btn3" Content="Применить" HorizontalAlignment="Left" Margin="153,353,0,0" VerticalAlignment="Top" FontSize="16" Height="29" Width="158" Background="White" FontFamily="Arial" Click="Button_Click1" Grid.Column="1">
                            <Button.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <DataGrid d:ItemsSource="{d:SampleData ItemCount=20}" AutoGenerateColumns="False" SelectionChanged="DataGrid_SelectionChanged_1" Height="326" VerticalAlignment="Top" FontSize="14" Grid.ColumnSpan="2">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ФИО" Binding="{Binding ФИО}" Width="200"/>
                                <DataGridTextColumn Header="логин" Binding="{Binding логин}" Width="200"/>
                                <DataGridTextColumn Header="пароль" Binding="{Binding пароль}" Width="200"/>
                                <DataGridComboBoxColumn CanUserResize="False" Width="200" Header="роль"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Удаление пользователя" Margin="-2,-2,-2,0">
                <Grid Background="#FFE5E5E5">
                    <Grid>
                        <Grid.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF8082FF" Offset="0.25"/>
                                <GradientStop Color="#FF3700FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Grid.Background>
                        <Button x:Name="btn3_Копировать" Content="Удалить" HorizontalAlignment="Center" Margin="0,350,0,0" VerticalAlignment="Top" FontSize="16" Height="29" Width="158" Background="White" FontFamily="Arial" Click="Button_Click1">
                            <Button.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <DataGrid d:ItemsSource="{d:SampleData ItemCount=20}" AutoGenerateColumns="False" SelectionChanged="DataGrid_SelectionChanged_1" Height="330" VerticalAlignment="Top" FontSize="14">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn CanUserResize="False"/>
                                <DataGridTextColumn Header="ФИО" Binding="{Binding ФИО}" Width="200"/>
                                <DataGridTextColumn Header="логин" Binding="{Binding логин}" Width="200"/>
                                <DataGridTextColumn Header="пароль" Binding="{Binding пароль}" Width="200"/>
                                <DataGridTextColumn Header="роль" Binding="{Binding роль}" Width="200"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Отчёт для налоговой" Margin="-2,-2,-2,0">
                <Grid Background="#FFE5E5E5">
                    <Grid>
                        <Grid.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF8082FF" Offset="0.25"/>
                                <GradientStop Color="#FF3700FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Grid.Background>
                        <Button x:Name="btn4" Content="Отправить" HorizontalAlignment="Center" Margin="0,337,0,0" VerticalAlignment="Top" FontSize="16" Height="29" Width="158" Background="White" FontFamily="Arial" Click="Button_Click1">
                            <Button.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Label VerticalAlignment="Top" x:Name="label8" Margin="0,68,0,0" HorizontalAlignment="Center" FontSize="22" FontWeight="Bold" FontFamily="Arial" Content="Выбирете отчётный период"/>
                        <ComboBox x:Name="comboB1" HorizontalAlignment="Center" Margin="0,162,0,0" VerticalAlignment="Top" Width="204"/>
                        <ComboBox x:Name="comboB2" HorizontalAlignment="Center" Margin="0,206,0,0" VerticalAlignment="Top" Width="204"/>
                        <ComboBox x:Name="comboB3" HorizontalAlignment="Center" Margin="0,253,0,0" VerticalAlignment="Top" Width="204"/>
                        <Label VerticalAlignment="Top" x:Name="label9" Margin="204,156,0,0" HorizontalAlignment="Left" FontSize="20" FontWeight="Bold" FontFamily="Arial" Content="Месяц"/>
                        <Label VerticalAlignment="Top" x:Name="label10" Margin="204,200,0,0" HorizontalAlignment="Left" FontSize="20" FontWeight="Bold" FontFamily="Arial" Content="Квартал"/>
                        <Label VerticalAlignment="Top" x:Name="label11" Margin="204,246,0,0" HorizontalAlignment="Left" FontSize="20" FontWeight="Bold" FontFamily="Arial" Content="Год"/>
                        <DataGrid x:Name="dataGrid" d:ItemsSource="{d:SampleData ItemCount=20}" AutoGenerateColumns="False" SelectionChanged="DataGrid_SelectionChanged_1" Height="317" VerticalAlignment="Top" FontSize="14" Margin="-2,108,1,0" Visibility="Hidden">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ФИО" Binding="{Binding ФИО}" Width="200"/>
                                <DataGridTextColumn Header="логин" Binding="{Binding логин}" Width="200"/>
                                <DataGridTextColumn Header="пароль" Binding="{Binding пароль}" Width="200"/>
                                <DataGridComboBoxColumn CanUserResize="False" Width="200" Header="роль" HeaderStringFormat=""/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>