<Window x:Class="Практическая_8.WindowAccountant"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Практическая_8"
        mc:Ignorable="d"
        Title="Отчёты для клиентов" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF8082FF" Offset="0.25"/>
                <GradientStop Color="#FF3700FF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Label Margin="0,20,0,0" VerticalAlignment="Top" x:Name="label1" HorizontalAlignment="Center" FontSize="22" FontWeight="Bold" FontFamily="Arial" Content="Формирование отчётов для клиентов"/>
        <Label Margin="0,121,0,0" VerticalAlignment="Top" x:Name="label2" HorizontalAlignment="Center" FontSize="18" FontWeight="Bold" FontFamily="Arial" Content="Выбирете клиента"/>
        <ComboBox HorizontalAlignment="Center" Margin="0,157,0,0" VerticalAlignment="Top" Width="176"/>
        <Label VerticalAlignment="Center" x:Name="label3" HorizontalAlignment="Center" FontSize="18" FontWeight="Bold" FontFamily="Arial" Content="Выбирете тип отчёта"/>
        <ComboBox HorizontalAlignment="Center" Margin="0,238,0,0" VerticalAlignment="Top" Width="176"/>
        <Button Content="Сформировать отчёт"  HorizontalAlignment="Center" Margin="0,341,0,0" VerticalAlignment="Top" FontSize="16" Height="45" Width="200" Background="White" FontFamily="Arial" Click="Button_Click">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>
