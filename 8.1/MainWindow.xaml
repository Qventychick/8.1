<Window x:Class="Практическая_8.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Практическая_8"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FF8082FF" Offset="0.69"/>
            <GradientStop Color="#FF0003B3" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <Image Margin="49,22,601,262" Source="/Лого.png" Stretch="Fill" Width="150" Height="150"/>
        <Label Content="Компания по подключению интернета «Голубь»" 
               HorizontalAlignment="Left" Margin="219,22,0,0" VerticalAlignment="Top" 
               FontSize="20" FontFamily="Arial" FontWeight="Bold" FontStyle="Italic"/>
        <Label Content="Голубь - интернет, который не улетит" 
               HorizontalAlignment="Left" Margin="356,64,0,0" VerticalAlignment="Top" 
               FontSize="20" FontFamily="Arial" FontWeight="Bold" FontStyle="Italic"/>
        <Label Content="Введите данные своей учетной записи" 
               HorizontalAlignment="Left" Margin="216,147,0,0" VerticalAlignment="Top" 
               FontSize="20" FontFamily="Arial" FontWeight="Bold"/>
        <Label Content="Логин:" 
               HorizontalAlignment="Left" Margin="239,198,0,0" VerticalAlignment="Top" 
               FontSize="20" FontFamily="Arial" FontWeight="Bold"/>
        <TextBox HorizontalAlignment="Left" Margin="330,203,0,0" 
                 TextWrapping="Wrap" VerticalAlignment="Top" Width="224" Height="22"
                 TextChanged="TextBox_TextChanged"/>
        <Label Content="Пароль:" 
               HorizontalAlignment="Left" Margin="224,255,0,0" VerticalAlignment="Top" 
               FontSize="20" FontFamily="Arial" FontWeight="Bold"/>
        <TextBox HorizontalAlignment="Left" Margin="330,260,0,0" 
                 TextWrapping="Wrap" VerticalAlignment="Top" Width="224" Height="22"
                 TextChanged="TextBox_TextChanged"/>
        <TextBlock Text="Пароль вылетел из вашей головы?" 
           HorizontalAlignment="Left" Margin="318,300,0,0" VerticalAlignment="Top" 
           FontSize="15" FontFamily="Arial" Foreground="White" FontWeight="Bold"
           Cursor="Hand" MouseDown="ForgotPassword">
            <TextBlock.Resources>
                <Style TargetType="TextBlock">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="Yellow"/>
                            <Setter Property="TextDecorations" Value="Underline"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Resources>
        </TextBlock>
        <Button Content="Вход (админ)" 
                HorizontalAlignment="Left" Margin="163,352,0,0" VerticalAlignment="Top" 
                FontSize="20" Height="45" Width="165" Background="White" FontFamily="Arial" Click="Button_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>
        <Button Content="Вход (бухгалтер)" 
            HorizontalAlignment="Left" Margin="556,352,0,0" VerticalAlignment="Top" 
            FontSize="20" Height="45" Width="194" Background="White" FontFamily="Arial" Click="Button_Click2">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>